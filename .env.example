# Copy this file to .env and fill in your values

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/portfolio
# OR for MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/portfolio

# JWT Secret Key (change this to a strong random string)
JWT_SECRET=your_super_secret_key_change_this_in_production_12345

# Admin Credentials (used for first-time setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
